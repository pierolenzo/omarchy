#!/bin/bash

# Run all pending migrations to bring the system in line with the installed version.

# Load abstraction layer
OMARCHY_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OMARCHY_LIB_DIR="$(cd "$OMARCHY_BIN_DIR/../lib" && pwd)"
source "$OMARCHY_LIB_DIR/pkg_abstraction.sh"

# Where we store an empty file for each migration that has already been performed.
STATE_DIR="$HOME/.local/state/omarchy/migrations"
mkdir -p "$STATE_DIR"

# Skipped migrations are tracked separately
mkdir -p "$STATE_DIR/skipped"

# Run any pending migrations
for file in ~/.local/share/omarchy/migrations/*.sh; do
  filename=$(basename "$file")

  if [[ ! -f "$STATE_DIR/$filename" && ! -f "$STATE_DIR/skipped/$filename" ]]; then

    # Auto-skip Arch-specific migrations on non-Arch systems
    if [ "$OMARCHY_DISTRO" != "arch" ]; then
        if grep -q "pacman" "$file" && ! grep -q "pkg_" "$file"; then
             echo -e "\e[33m\nSkipping Arch-specific migration ($filename) on $OMARCHY_DISTRO\e[0m"
             touch "$STATE_DIR/skipped/$filename"
             continue
        fi
        # Also skip migrations editing /etc/pacman.conf directly
        if grep -q "/etc/pacman.conf" "$file"; then
             echo -e "\e[33m\nSkipping pacman.conf migration ($filename) on $OMARCHY_DISTRO\e[0m"
             touch "$STATE_DIR/skipped/$filename"
             continue
        fi
    fi

    echo -e "\e[32m\nRunning migration (${filename%.sh})\e[0m"

    if bash $file; then
      touch "$STATE_DIR/$filename"
    else
      if gum confirm "Migration ${filename%.sh} failed. Skip and continue?"; then
        touch "$STATE_DIR/skipped/$filename"
      else
        exit 1
      fi
    fi
  fi
done
