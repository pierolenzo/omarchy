#!/bin/bash

# Show a fuzzy-finder TUI for picking new Arch and OPR packages to install.

# Load abstraction layer
OMARCHY_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OMARCHY_LIB_DIR="$(cd "$OMARCHY_BIN_DIR/../lib" && pwd)"
source "$OMARCHY_LIB_DIR/pkg_abstraction.sh"

fzf_args=(
  --multi
  --preview "bash -c 'source \"$OMARCHY_LIB_DIR/pkg_abstraction.sh\"; pkg_info {1}'"
  --preview-label='alt-p: toggle description, alt-j/k: scroll, tab: multi-select'
  --preview-label-pos='bottom'
  --preview-window 'down:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --color 'pointer:green,marker:green'
)

pkg_names=$(pkg_list_all | fzf "${fzf_args[@]}")

if [[ -n "$pkg_names" ]]; then
  # Convert to array
  mapfile -t selected_pkgs <<< "$pkg_names"
  pkg_install "${selected_pkgs[@]}"
  omarchy-show-done
fi
