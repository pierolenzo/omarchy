#!/bin/bash

# Load abstraction layer
OMARCHY_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OMARCHY_LIB_DIR="$(cd "$OMARCHY_BIN_DIR/../lib" && pwd)"
source "$OMARCHY_LIB_DIR/pkg_abstraction.sh"

if [ "$OMARCHY_DISTRO" == "gentoo" ]; then
    last_merge=$(grep " >>> emerge " /var/log/emerge.log 2>/dev/null | tail -1 | cut -d: -f1)
    if [ -n "$last_merge" ]; then
        date -d "@$last_merge" "+%A, %B %d %Y at %H:%M"
    else
        echo "Unknown"
    fi
else
    date -d "$(grep upgraded /var/log/pacman.log | tail -1 | sed -E 's/\[([^]]+)\].*/\1/')" "+%A, %B %d %Y at %H:%M"
fi
